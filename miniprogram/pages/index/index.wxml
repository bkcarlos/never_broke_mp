<view class="page">
  <view class="nb-card" wx:if="{{overview}}">
    <view class="nb-title">{{i18n.todayExpense}}</view>
    <view class="big">{{display.todayExpense}}</view>
    <text class="nb-muted">{{display.todayCount}}</text>
  </view>

  <view class="nb-card" wx:if="{{overview}}">
    <view class="nb-title">{{i18n.monthBudget}}</view>
    <view class="row">
      <text>{{display.budgetLine}}</text>
    </view>
    <view class="bar-bg">
      <view class="bar-fill {{budgetBarClass}}" style="width: {{budgetPercent}}%;"></view>
    </view>
    <text class="nb-muted">{{display.budgetRemain}}</text>
  </view>

  <view class="nb-card" wx:if="{{overview}}">
    <view class="nb-title">{{i18n.assetsOverview}}</view>
    <view class="big">{{display.assetsTotal}}</view>
    <view class="split">
      <text>{{i18n.multiAccount}}</text>
      <text class="nb-muted">{{i18n.seeAccounts}}</text>
    </view>
  </view>

  <view class="actions">
    <button class="mini primary" bindtap="goRecord">{{i18n.recordBtn}}</button>
    <button class="mini" bindtap="goTransfer">{{i18n.transferBtn}}</button>
    <button class="mini" bindtap="goReports">{{i18n.reportsBtn}}</button>
  </view>
</view>
