<view class="page">
  <view class="toolbar">
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="date-btn">{{date}} 📅</view>
    </picker>
  </view>

  <view class="filters">
    <picker mode="selector" range="{{typeLabels}}" value="{{typeIndex}}" bindchange="onTypeFilter">
      <view class="filter-chip">{{typeLabels[typeIndex]}}</view>
    </picker>
    <picker mode="selector" range="{{accountNames}}" value="{{accountIndex}}" bindchange="onAccountFilter">
      <view class="filter-chip">{{accountNames[accountIndex]}}</view>
    </picker>
    <picker mode="selector" range="{{categoryLabels}}" value="{{categoryIndex}}" bindchange="onCategoryFilter">
      <view class="filter-chip narrow">{{categoryLabels[categoryIndex]}}</view>
    </picker>
  </view>

  <view class="summary nb-muted" wx:if="{{summary}}">
    {{i18n.income}} {{summary.income}}　{{i18n.expense}} {{summary.expense}}
  </view>

  <view wx:if="{{list.length === 0}}" class="empty">{{i18n.noRecord}}</view>

  <block wx:for="{{list}}" wx:key="_id">
    <view class="tx-card" bindtap="onTapTx" data-id="{{item._id}}">
      <view class="tx-row">
        <text class="tx-cat">{{item.categoryLabel}}</text>
        <text class="tx-amt {{item.type}}">{{item.type === 'expense' ? '-' : item.type === 'income' ? '+' : '↔'}}{{item.displayAmount}}</text>
      </view>
      <text class="tx-note nb-muted">{{item.note || i18n.noNote}}</text>
      <text class="tx-time nb-muted">{{item.type === 'income' ? i18n.income : item.type === 'expense' ? i18n.expense : i18n.transfer}}</text>
    </view>
  </block>

  <view class="fab" bindtap="goRecord">+</view>
</view>
