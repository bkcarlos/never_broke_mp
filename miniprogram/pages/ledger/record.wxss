.page {
  padding: 24rpx 24rpx 80rpx;
}

.quick-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.quick-scroll {
  flex: 1;
  white-space: nowrap;
}

.quick-chip {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  background: #fff;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #333;
  border: 1px solid #e5e5e5;
}

.tabs {
  display: flex;
  margin-bottom: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 30rpx;
  color: #666;
}

.tab.on {
  background: #1aad19;
  color: #fff;
  font-weight: 600;
}

.tab.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.inp {
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  font-size: 28rpx;
}

.row {
  display: flex;
  align-items: center;
}

.chk-wrap {
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.save {
  margin-top: 48rpx;
  background: #1aad19 !important;
  border-radius: 16rpx !important;
}
