.page {
  padding-bottom: 160rpx;
}

.toolbar {
  padding: 24rpx;
}

.filters {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 24rpx 16rpx;
}

.filter-chip {
  display: inline-block;
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: #fff;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #333;
  border: 1px solid #e5e5e5;
}

.filter-chip.narrow {
  max-width: 160rpx;
}

.date-btn {
  display: inline-block;
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.summary {
  padding: 0 24rpx 16rpx;
  font-size: 26rpx;
}

.empty {
  text-align: center;
  color: #999;
  margin-top: 120rpx;
}

.tx-card {
  background: #fff;
  margin: 0 24rpx 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.tx-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tx-cat {
  font-size: 30rpx;
  font-weight: 500;
}

.tx-amt {
  font-size: 30rpx;
  font-weight: 600;
}

.tx-amt.expense {
  color: #ff6b6b;
}

.tx-amt.income {
  color: #1aad19;
}

.tx-note,
.tx-time {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
}

.fab {
  position: fixed;
  right: 48rpx;
  bottom: 120rpx;
  width: 112rpx;
  height: 112rpx;
  line-height: 112rpx;
  text-align: center;
  border-radius: 50%;
  background: #1aad19;
  color: #fff;
  font-size: 56rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 173, 25, 0.4);
}
