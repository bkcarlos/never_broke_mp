<view class="page">
  <view class="quick-row" wx:if="{{!isEdit}}">
    <text class="quick-label">{{i18n.quickLabel}}</text>
    <scroll-view class="quick-scroll" scroll-x="true" show-scrollbar="{{false}}">
      <view
        class="quick-chip"
        wx:for="{{quickTemplates}}"
        wx:key="label"
        data-i="{{index}}"
        bindtap="applyQuick"
      >{{item.label}}</view>
    </scroll-view>
  </view>

  <view class="tabs">
    <view class="tab {{kind==='expense'?'on':''}} {{isEdit?'disabled':''}}" data-k="expense" bindtap="setKind">{{i18n.expense}}</view>
    <view class="tab {{kind==='income'?'on':''}} {{isEdit?'disabled':''}}" data-k="income" bindtap="setKind">{{i18n.income}}</view>
  </view>

  <view class="field">
    <text class="label">{{i18n.amount}}</text>
    <block wx:for="{{[formKey]}}" wx:key="*this">
      <amount-input value="{{amount}}" bind:change="onAmount" />
    </block>
  </view>
  <view class="field">
    <text class="label">{{i18n.category}}</text>
    <category-picker categories="{{categories}}" value="{{category}}" bind:change="onCategory" />
  </view>
  <view class="field">
    <text class="label">{{i18n.account}}</text>
    <account-picker accounts="{{accounts}}" value="{{accountId}}" bind:change="onAccount" />
  </view>
  <view class="field">
    <text class="label">{{i18n.date}}</text>
    <date-picker value="{{date}}" bind:change="onDate" />
  </view>
  <view class="field">
    <text class="label">{{i18n.note}}</text>
    <input class="inp" placeholder="{{i18n.notePlaceholder}}" value="{{note}}" bindinput="onNote" />
  </view>

  <view class="field row" wx:if="{{kind==='expense'}}">
    <label class="chk-wrap">
      <checkbox checked="{{createInstallment}}" bindtap="toggleInst" />
      <text>{{i18n.createInstallment}}</text>
    </label>
  </view>
  <view class="field" wx:if="{{kind==='expense' && createInstallment}}">
    <text class="label">{{i18n.installmentPeriods}}</text>
    <input class="inp" type="number" placeholder="{{i18n.installmentPlaceholder}}" value="{{installments}}" bindinput="onInst" />
  </view>

  <button class="save" type="primary" bindtap="save">{{isEdit ? i18n.saveEdit : i18n.save}}</button>
</view>
