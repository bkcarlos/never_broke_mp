<view class="wrap">
  <view class="brand">
    <image class="logo" src="/images/neverbroke-logo.svg" mode="aspectFit" />
    <text class="sub">认知翻身账</text>
    <text class="name">NeverBroke</text>
    <text class="slogan">从糊涂花钱到心里有数</text>
    <text class="slogan slogan-accent">现金流往上走</text>
  </view>

  <view class="login-footer">
    <button class="btn-main" type="primary" bindtap="onWechatLogin">微信一键登录</button>

    <view class="agree">
      <view class="agree-row">
        <checkbox class="agree-check" checked="{{agreed}}" bindtap="toggleAgree" />
        <view class="agree-texts">
          <text class="agree-plain">已阅读并同意</text>
          <text class="link" catchtap="showTerms">《用户协议》</text>
          <text class="agree-plain">与</text>
          <text class="link" catchtap="showPrivacy">《隐私政策》</text>
        </view>
      </view>
    </view>
  </view>
</view>
