.wrap {
  min-height: 100vh;
  padding: 80rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #e8f5e9 0%, #f5f5f5 40%);
}

.brand {
  text-align: center;
  margin-bottom: 120rpx;
}

.name {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1aad19;
}

.sub {
  display: block;
  margin-top: 16rpx;
  font-size: 32rpx;
  color: #333;
}

.slogan {
  display: block;
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #999;
}

.btn-main {
  background: #1aad19 !important;
  border-radius: 16rpx !important;
  margin-bottom: 48rpx;
}

.agree {
  display: flex;
  align-items: flex-start;
  font-size: 22rpx;
  color: #999;
}

.agree-text {
  flex: 1;
  margin-left: 8rpx;
  line-height: 1.5;
}
