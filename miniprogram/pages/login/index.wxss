.wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 80rpx 48rpx 0;
  box-sizing: border-box;
  background: linear-gradient(180deg, #e8f5e9 0%, #f5f5f5 40%);
}

.brand {
  flex: 1;
  min-height: 0;
  text-align: center;
  margin-bottom: 48rpx;
}

.logo {
  display: block;
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 32rpx;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 173, 25, 0.2);
  background: #fff;
}

.sub {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.name {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1aad19;
  margin-bottom: 28rpx;
}

.slogan {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.65;
}

.slogan.slogan-accent {
  margin-top: 10rpx;
  color: #1aad19;
  font-weight: 600;
  font-size: 28rpx;
}

.login-footer {
  flex-shrink: 0;
  padding-bottom: 80rpx;
  padding-bottom: calc(80rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
}

.btn-main {
  margin-top: 0;
  background: #1aad19 !important;
  border-radius: 16rpx !important;
  margin-bottom: 48rpx;
}

.agree {
  width: 100%;
  text-align: center;
}

.agree-row {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: nowrap;
  max-width: 100%;
  vertical-align: middle;
  text-align: left;
}

.agree-check {
  flex-shrink: 0;
  margin-right: 8rpx;
}

.agree-texts {
  flex: 0 1 auto;
  min-width: 0;
  height: 64rpx;
  line-height: 64rpx;
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.agree-plain {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}

.link {
  font-size: 22rpx;
  color: #1aad19 !important;
  text-decoration: underline;
  line-height: 1.4;
  padding: 0 2rpx;
}
