<view class="page">
  <view class="tabs">
    <view class="tab {{days===30?'on':''}}" data-d="30" bindtap="setDays">30天</view>
    <view class="tab {{days===60?'on':''}}" data-d="60" bindtap="setDays">60天</view>
    <view class="tab {{days===90?'on':''}}" data-d="90" bindtap="setDays">90天</view>
  </view>

  <view class="nb-card" wx:if="{{forecast}}">
    <view class="nb-title">摘要</view>
    <text class="line">当前折算余额：{{forecast.currentBalance}}</text>
    <text class="line">平均日支出（近30天）：{{forecast.avgDailyExpense}}</text>
    <text class="line">预测最低：{{forecast.minBalance}}（{{forecast.minBalanceDate}}）</text>
    <view class="risk" wx:if="{{forecast.risks.length}}">
      <text>风险提示：{{forecast.risks[0].message}}（{{forecast.risks[0].date}}）</text>
    </view>
  </view>

  <view class="nb-card" wx:if="{{chartPoints.length}}">
    <view class="nb-title">余额走势</view>
    <canvas type="2d" id="cfLineCanvas" class="cf-canvas"></canvas>
    <view class="spark">
      <block wx:for="{{chartPoints}}" wx:key="date">
        <view class="dot-col">
          <view class="dot" style="bottom: {{item.pct}}%;"></view>
        </view>
      </block>
    </view>
    <scroll-view scroll-x class="labels">
      <block wx:for="{{chartPoints}}" wx:key="date">
        <text class="lab">{{item.date.slice(5)}}</text>
      </block>
    </scroll-view>
  </view>
</view>
