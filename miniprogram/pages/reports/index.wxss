.page {
  padding-bottom: 48rpx;
}

.chart-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.chart-pie {
  width: 520rpx;
  height: 280rpx;
}

.line-wrap {
  margin-top: 8rpx;
}

.chart-line {
  width: 100%;
  height: 240rpx;
}

.month-bar {
  margin: 24rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.green {
  color: #1aad19;
  font-weight: 600;
}

.red {
  color: #ff6b6b;
  font-weight: 600;
}

.cat-row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  margin-top: 16rpx;
}

.bar-bg {
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  margin: 8rpx 0 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: #1aad19;
  border-radius: 6rpx;
  max-width: 100%;
}

.trend-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}

.trend-row > text:first-child {
  width: 160rpx;
}

.trend-bar-wrap {
  flex: 1;
  height: 16rpx;
  background: #eee;
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.trend-bar {
  height: 100%;
  background: #1aad19;
  border-radius: 8rpx;
  max-width: 100%;
}

.trend-val {
  width: 120rpx;
  text-align: right;
}

.links {
  padding: 24rpx;
}

.link {
  display: block;
  background: #fff;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  color: #1aad19;
}
