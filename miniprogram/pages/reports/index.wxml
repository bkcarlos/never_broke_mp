<view class="page">
  <picker mode="date" fields="month" value="{{monthPicker}}" bindchange="onMonth">
    <view class="month-bar">{{yearMonth}}</view>
  </picker>

  <view class="nb-card" wx:if="{{summary}}">
    <view class="nb-title">{{i18n.monthlySummary}}</view>
    <view class="row nb-muted" wx:if="{{summary.multiCurrency}}">{{i18n.multiCurrencyHint}}</view>
    <view wx:for="{{summary.rows}}" wx:key="currency" class="currency-block">
      <view class="row nb-muted">{{item.currency}}</view>
      <view class="row"><text>{{i18n.income}}</text><text class="green">{{item.income}}</text></view>
      <view class="row"><text>{{i18n.expense}}</text><text class="red">{{item.expense}}</text></view>
      <view class="row"><text>{{i18n.balance}}</text><text>{{item.balance}}</text></view>
    </view>
  </view>

  <view class="nb-card" wx:for="{{categorySections}}" wx:key="currency" wx:if="{{item.categories.length}}">
    <view class="nb-title">{{i18n.categoryRatio}}（{{item.currency}}）</view>
    <view class="chart-wrap" wx:if="{{showCharts && index === 0}}">
      <canvas type="2d" id="pieCanvas" class="chart-pie"></canvas>
    </view>
    <block wx:for="{{item.categories}}" wx:for-item="cat" wx:for-index="catIdx" wx:key="name">
      <view class="cat-row">
        <text>{{cat.displayName}}</text>
        <text>{{cat.amount}} ({{cat.ratio}}%)</text>
      </view>
      <view class="bar-bg">
        <view class="bar-fill" style="width: {{cat.ratio}}%;"></view>
      </view>
    </block>
  </view>

  <view class="nb-card" wx:for="{{trendSections}}" wx:key="currency" wx:if="{{item.list.length}}">
    <view class="nb-title">{{i18n.trend6Months}}（{{item.currency}}）</view>
    <view class="chart-wrap line-wrap" wx:if="{{showCharts && index === 0}}">
      <canvas type="2d" id="lineCanvas" class="chart-line"></canvas>
    </view>
    <block wx:for="{{item.list}}" wx:for-item="row" wx:for-index="rowIdx" wx:key="yearMonth">
      <view class="trend-row">
        <text>{{row.yearMonth}}</text>
        <view class="trend-bar-wrap">
          <view class="trend-bar" style="width: {{row.barPct}}%;"></view>
        </view>
        <text class="trend-val">{{row.expense}}</text>
      </view>
    </block>
  </view>

  <view class="links">
    <navigator url="/pages/reports/cashflow" class="link">{{i18n.cashflow}}</navigator>
    <navigator url="/pages/reports/timeline" class="link">{{i18n.timeline}}</navigator>
  </view>
</view>
