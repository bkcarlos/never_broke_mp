<view class="page">
  <view class="tabs">
    <view class="tab {{mode==='past'?'on':''}}" data-m="past" bindtap="setMode">{{i18n.history}}</view>
    <view class="tab {{mode==='future'?'on':''}}" data-m="future" bindtap="setMode">{{i18n.future}}</view>
  </view>

  <block wx:if="{{mode==='past'}}">
    <view class="toolbar">
      <picker mode="selector" range="{{pastRangeLabels}}" value="{{pastRangeIndex}}" bindchange="onPastRange">
        <view class="range-chip">{{pastRangeLabels[pastRangeIndex]}}</view>
      </picker>
    </view>
    <view wx:if="{{!pastList.length}}" class="empty nb-muted">{{i18n.noRecords}}</view>
    <block wx:for="{{pastList}}" wx:key="date">
      <view class="nb-card">
        <view class="nb-row" bindtap="toggleExpand" data-date="{{item.date}}">
          <view class="nb-title">{{item.date}}</view>
          <text class="chev">{{expandedDate === item.date ? '▼' : '▶'}}</text>
        </view>
        <text class="nb-muted">{{i18n.income}} {{item.income}}　{{i18n.expense}} {{item.expense}}　{{item.countLabel}}</text>
        <button size="mini" class="mt-btn" bindtap="showDetail" data-date="{{item.date}}">{{i18n.viewDetail}}</button>
        <view wx:if="{{expandedDate === item.date}}" class="expand-tip nb-muted">{{i18n.expandHint}}</view>
      </view>
    </block>
  </block>

  <block wx:if="{{mode==='future'}}">
    <view class="nb-card" wx:if="{{!futureList.length}}">
      <text class="nb-muted">{{i18n.noFuturePlans}}</text>
    </view>
    <block wx:for="{{futureList}}" wx:key="date">
      <view class="nb-card">
        <view class="nb-title">{{item.date}}</view>
        <view wx:if="{{item.inflows.length}}">
          <text class="sub-h">{{i18n.projectedIncome}}</text>
          <block wx:for="{{item.inflows}}" wx:for-item="inc" wx:for-index="ii" wx:key="ii">
            <text class="line">· {{inc.name}} {{inc.amount}}</text>
          </block>
        </view>
        <view wx:if="{{item.outflows.length}}">
          <text class="sub-h">{{i18n.projectedExpense}}</text>
          <block wx:for="{{item.outflows}}" wx:for-item="out" wx:for-index="oi" wx:key="oi">
            <text class="line">· {{out.name}} {{out.amount}}</text>
          </block>
        </view>
      </view>
    </block>
  </block>
</view>
