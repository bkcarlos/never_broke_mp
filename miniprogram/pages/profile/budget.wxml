<view class="page">
  <view class="nb-card">
    <text class="nb-muted">{{i18n.monthThis}}</text>
    <view class="field">
      <text class="label">{{i18n.monthTotalBudget}}</text>
      <input class="inp" type="digit" placeholder="{{i18n.inputPlaceholder}}" value="{{totalBudget}}" bindinput="onBudget" />
    </view>
    <button class="btn-secondary" size="mini" bindtap="copyPrev">{{i18n.copyPrevBudget}}</button>
    <view wx:if="{{usage}}">
      <text class="usage-line">{{usage.line}}</text>
      <view class="bar-bg">
        <view class="bar-fill {{barClass}}" style="width: {{usage.pct}}%;"></view>
      </view>
    </view>
    <view class="field row-check">
      <view class="chk-wrap" bindtap="toggleAlert80">
        <checkbox checked="{{alert80}}" />
        <text>{{i18n.alertAt80}}</text>
      </view>
    </view>
    <view class="field row-check">
      <view class="chk-wrap" bindtap="toggleAlertOver">
        <checkbox checked="{{alertOver}}" />
        <text>{{i18n.alertWhenOver}}</text>
      </view>
    </view>
    <button type="primary" class="btn" bindtap="save">{{i18n.save}}</button>
  </view>

  <view class="nb-card" wx:if="{{history.length}}">
    <view class="nb-title">{{i18n.historyExecution}}</view>
    <block wx:for="{{history}}" wx:key="yearMonth">
      <view class="hist-row">
        <text class="hist-ym">{{item.label}}</text>
        <text class="hist-num {{item.over ? 'over' : ''}}">{{item.usedFmt}} / {{item.totalFmt}} ({{item.pct}}%)</text>
      </view>
    </block>
  </view>
</view>
