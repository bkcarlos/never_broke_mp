.page {
  padding: 24rpx;
}

.label {
  display: block;
  margin: 16rpx 0 8rpx;
  color: #666;
  font-size: 26rpx;
}

.inp {
  padding: 20rpx;
  background: #fff;
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
}

.sub {
  margin-top: 24rpx;
  background: #fff;
  color: #1aad19;
  border: 1px solid #1aad19;
}

.tip {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.5;
}
