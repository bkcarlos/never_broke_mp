.page {
  padding: 24rpx;
}

.mt {
  margin-top: 16rpx;
}

.inst-scroll {
  margin: 16rpx 0;
  white-space: nowrap;
}

.inst-row {
  display: inline-flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 4rpx 0;
}

.inst-chip {
  display: inline-block;
  padding: 12rpx 24rpx;
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  background: #fff;
  font-size: 26rpx;
  flex-shrink: 0;
}

.inst-chip.on {
  border-color: #1aad19;
  color: #1aad19;
  background: #f6ffed;
}

.inp {
  padding: 16rpx;
  background: #fff;
  border-radius: 8rpx;
  border: 1px solid #e5e5e5;
  margin: 16rpx 0;
}

.preview-result {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.section {
  margin: 24rpx 0 12rpx;
  color: #999;
  font-size: 26rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.title {
  font-weight: 600;
}

.btn-prev {
  margin-top: 16rpx;
  background: #1aad19 !important;
  color: #fff !important;
}

.badge {
  font-size: 24rpx;
  color: #666;
}

.plan-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.plan-card {
  margin-bottom: 16rpx;
}

.empty {
  padding: 24rpx;
  text-align: center;
  font-size: 26rpx;
}

.done {
  opacity: 0.85;
}

.done .title.muted {
  color: #999;
}
