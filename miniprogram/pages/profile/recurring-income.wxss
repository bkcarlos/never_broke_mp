.page {
  padding: 24rpx;
}

.section {
  margin: 16rpx 0;
  color: #999;
  font-size: 26rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.t {
  font-weight: 600;
}

.inp {
  border: 1px solid #e5e5e5;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  background: #fff;
}

.freq {
  display: flex;
  flex-wrap: wrap;
  margin: 16rpx 0;
  font-size: 26rpx;
}

.freq-item {
  margin-right: 24rpx;
  margin-bottom: 12rpx;
}

.small-label {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
}

.freq-scroll {
  margin: 16rpx 0;
  white-space: nowrap;
}

.freq-row {
  display: inline-flex;
  flex-direction: row;
  gap: 16rpx;
}

.freq-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  background: #fff;
  font-size: 26rpx;
  flex-shrink: 0;
}

.freq-chip.on {
  border-color: #1aad19;
  color: #1aad19;
  background: #f6ffed;
}

.btn {
  margin-top: 24rpx;
  background: #1aad19 !important;
}

.nb-card.due {
  border: 1px solid #ffe58f;
  background: #fffbe6;
}

.due-tag {
  font-size: 22rpx;
  color: #d48806;
  background: #fff1b8;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.sub-line {
  display: block;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.row-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}
