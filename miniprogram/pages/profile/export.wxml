<view class="page">
  <view class="nb-card">
    <text class="label">{{i18n.quickRange}}</text>
    <view class="preset-row">
      <button
        wx:for="{{presetLabels}}"
        wx:key="*this"
        size="mini"
        class="preset-btn"
        data-i="{{index}}"
        bindtap="applyPreset"
      >{{item}}</button>
    </view>
    <text class="label">{{i18n.startDate}}</text>
    <picker mode="date" value="{{startDate}}" bindchange="onStart">
      <view class="inp">{{startDate}}</view>
    </picker>
    <text class="label">{{i18n.endDate}}</text>
    <picker mode="date" value="{{endDate}}" bindchange="onEnd">
      <view class="inp">{{endDate}}</view>
    </picker>
    <button type="primary" bindtap="generate">{{i18n.generate}}</button>
  </view>

  <!-- Export success card -->
  <view class="nb-card result-card" wx:if="{{url}}">
    <view class="result-header">
      <text class="result-icon">✅</text>
      <view class="result-text">
        <text class="result-title">{{i18n.successTitle}}</text>
        <text class="result-desc">{{i18n.successDesc}}</text>
      </view>
    </view>
    <view class="result-actions">
      <button
        size="mini"
        class="result-btn"
        type="{{hasJustCopied ? 'default' : 'primary'}}"
        bindtap="copy"
      >{{hasJustCopied ? i18n.copied : i18n.copyLink}}</button>
      <button
        size="mini"
        class="result-btn {{hasDownloaded ? 'btn-muted' : ''}}"
        bindtap="open"
      >{{i18n.tryOpen}}</button>
    </view>
  </view>
</view>
