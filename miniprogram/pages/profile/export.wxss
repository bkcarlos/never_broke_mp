.page {
  padding: 24rpx;
}

.preset-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.preset-btn {
  margin: 0 !important;
}

.label {
  display: block;
  margin: 16rpx 0 8rpx;
  color: #666;
  font-size: 26rpx;
}

.inp {
  padding: 20rpx;
  background: #fff;
  border-radius: 8rpx;
  border: 1px solid #e5e5e5;
  margin-bottom: 16rpx;
}

.break {
  display: block;
  margin-top: 16rpx;
  word-break: break-all;
  font-size: 22rpx;
}
