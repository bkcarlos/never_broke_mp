.page {
  padding: 24rpx;
}

.preset-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.preset-btn {
  margin: 0 !important;
}

.label {
  display: block;
  margin: 16rpx 0 8rpx;
  color: #666;
  font-size: 26rpx;
}

.inp {
  padding: 20rpx;
  background: #fff;
  border-radius: 8rpx;
  border: 1px solid #e5e5e5;
  margin-bottom: 16rpx;
}

.break {
  display: block;
  margin-top: 16rpx;
  word-break: break-all;
  font-size: 22rpx;
}

.result-card {
  margin-top: 24rpx;
}

.result-header {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.result-icon {
  font-size: 32rpx;
  line-height: 1.4;
}

.result-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.result-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.result-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.result-btn {
  margin: 0;
}

.btn-muted {
  opacity: 0.88;
}
