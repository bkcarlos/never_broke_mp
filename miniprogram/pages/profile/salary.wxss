.page {
  padding: 24rpx;
}

.inp {
  border: 1px solid #e5e5e5;
  padding: 20rpx;
  margin: 16rpx 0;
  border-radius: 8rpx;
  background: #fff;
}

.result {
  margin-top: 24rpx;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.line {
  display: block;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.line.strong {
  font-weight: 700;
  font-size: 30rpx;
  margin-top: 12rpx;
}

.section {
  margin: 24rpx 0 12rpx;
  color: #999;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.t {
  font-weight: 600;
}

.forecast-block {
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1px solid #ececec;
}

.forecast-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.forecast-row {
  padding: 16rpx 0;
  border-top: 1px solid #efefef;
}

.forecast-month {
  display: block;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.forecast-item {
  display: block;
  font-size: 24rpx;
  color: #555;
  margin-bottom: 4rpx;
}

