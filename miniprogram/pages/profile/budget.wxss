.page {
  padding: 24rpx;
}

.field {
  margin: 24rpx 0;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: #666;
  font-size: 26rpx;
}

.inp {
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  padding: 20rpx;
  background: #fff;
}

.bar-bg {
  height: 16rpx;
  background: #eee;
  border-radius: 8rpx;
  margin-top: 16rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: #1aad19;
  max-width: 100%;
}

.btn {
  margin-top: 32rpx;
  background: #1aad19 !important;
  border-radius: 16rpx !important;
}
