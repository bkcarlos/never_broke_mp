.page {
  padding: 24rpx;
}

.field {
  margin: 24rpx 0;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: #666;
  font-size: 26rpx;
}

.inp {
  border: 1px solid #e5e5e5;
  border-radius: 8rpx;
  padding: 20rpx;
  background: #fff;
}

.bar-bg {
  height: 16rpx;
  background: #eee;
  border-radius: 8rpx;
  margin-top: 16rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: #52c41a;
  max-width: 100%;
}

.bar-fill.ok {
  background: #52c41a;
}

.bar-fill.warn {
  background: #faad14;
}

.bar-fill.danger {
  background: #ff6b6b;
}

.btn-secondary {
  margin: 16rpx 0 8rpx;
  background: #fff !important;
  color: #1aad19 !important;
  border: 1px solid #1aad19 !important;
}

.usage-line {
  font-size: 28rpx;
  margin-top: 16rpx;
}

.row-check {
  margin: 16rpx 0;
}

.chk-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
}

.nb-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.hist-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1px solid #f0f0f0;
  font-size: 26rpx;
}

.hist-ym {
  color: #666;
}

.hist-num {
  color: #333;
}

.hist-num.over {
  color: #ff6b6b;
}

.btn {
  margin-top: 32rpx;
  background: #1aad19 !important;
  border-radius: 16rpx !important;
}
