<view class="page">
  <view class="onboard-tip" wx:if="{{onboarding}}">
    <text class="onboard-title">{{i18n.onboardingWelcome}}</text>
    <text class="onboard-desc">{{i18n.onboardingDesc}}</text>
  </view>
  <view class="field">
    <text class="label">{{i18n.typeLabel}}</text>
    <scroll-view scroll-x class="type-scroll" enable-flex="{{true}}" show-scrollbar="{{false}}">
      <view class="type-group">
        <view
          wx:for="{{types}}"
          wx:key="value"
          class="type-btn {{type === item.value ? 'on' : ''}} {{isEdit ? 'disabled' : ''}}"
          data-value="{{item.value}}"
          bindtap="onTypeTap"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="field" wx:if="{{type==='bank' || type==='credit' || type==='savings'}}">
    <text class="label">{{i18n.institutionBankLabel}}</text>
    <picker range="{{banks}}" value="{{bankIndex}}" bindchange="onBankPick">
      <view class="inp">{{banks[bankIndex] || i18n.choosePlaceholder}}</view>
    </picker>
    <text class="nb-muted small-tip" wx:if="{{bankIndex === banks.length - 1}}">{{i18n.bankOtherHint}}</text>
    <input wx:if="{{bankIndex === banks.length - 1}}" class="inp mt" placeholder="{{i18n.institutionPlaceholder}}" value="{{bank}}" bindinput="onBankInput" />
  </view>

  <view class="field" wx:if="{{type==='wallet'}}">
    <text class="label">{{i18n.institutionLabel}}</text>
    <scroll-view scroll-x class="type-scroll" enable-flex="{{true}}" show-scrollbar="{{false}}">
      <view class="type-group">
        <view
          wx:for="{{walletInstitutions}}"
          wx:key="value"
          class="type-btn {{walletInstIndex === index ? 'on' : ''}}"
          data-index="{{index}}"
          bindtap="onWalletInstTap"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>
    <input wx:if="{{walletInstitutions[walletInstIndex].value === 'other'}}" class="inp mt" placeholder="{{i18n.walletCustomPlaceholder}}" value="{{walletCustom}}" bindinput="onWalletCustom" />
  </view>

  <view class="field" wx:if="{{type==='bank' || type==='credit' || type==='savings'}}">
    <text class="label">{{i18n.cardLast4Label}}</text>
    <input class="inp" type="number" maxlength="4" placeholder="{{i18n.cardLast4Placeholder}}" value="{{cardLast4}}" bindinput="onCardLast4" />
  </view>

  <view class="field">
    <text class="label">{{type === 'credit' ? i18n.initialBalanceUsedLabel : i18n.initialBalanceLabel}}</text>
    <text class="nb-muted" wx:if="{{type==='credit'}}">{{i18n.creditBalanceHint}}</text>
    <block wx:for="{{[formKey]}}" wx:key="*this" wx:for-item="_fk">
      <amount-input value="{{balance}}" bind:change="onBal" />
    </block>
  </view>
  <view class="field" wx:if="{{type==='credit'}}">
    <text class="label">{{i18n.creditLimitLabel}}</text>
    <block wx:for="{{[formKey]}}" wx:key="*this" wx:for-item="_fk">
      <amount-input value="{{creditLimit}}" bind:change="onLimit" />
    </block>
  </view>
  <view class="field" wx:if="{{type==='credit'}}">
    <text class="label">{{i18n.tempLimitLabel}}</text>
    <block wx:for="{{[formKey]}}" wx:key="*this" wx:for-item="_fk">
      <amount-input value="{{tempLimit}}" bind:change="onTempLimit" />
    </block>
  </view>
  <view class="field">
    <text class="label">{{i18n.currencyLabel}}</text>
    <scroll-view scroll-x class="type-scroll" enable-flex="{{true}}" show-scrollbar="{{false}}">
      <view class="type-group">
        <view
          wx:for="{{currencies}}"
          wx:key="*this"
          class="type-btn {{ci === index ? 'on' : ''}}"
          data-index="{{index}}"
          bindtap="onCurrencyTap"
        >
          {{item}}
        </view>
      </view>
    </scroll-view>
  </view>
  <button type="primary" class="btn" bindtap="save">{{isEdit ? i18n.saveBtn : i18n.createBtn}}</button>
  <button wx:if="{{onboarding}}" class="btn-skip" bindtap="skipOnboarding">{{i18n.skipBtn}}</button>
</view>
