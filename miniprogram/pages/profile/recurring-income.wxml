<view class="page">
  <view class="section">进行中的周期收入</view>
  <block wx:for="{{list}}" wx:key="_id">
    <view class="nb-card {{item.isDue ? 'due' : ''}}">
      <view class="row">
        <text class="t">{{item.name}}</text>
        <text class="due-tag" wx:if="{{item.isDue}}">已到期</text>
      </view>
      <text class="sub-line">{{item.displayAmount}} · {{item.frequency}}</text>
      <text class="nb-muted">下次到期 {{item.nextDueDate}}</text>
      <view class="row-btns">
        <button size="mini" type="primary" bindtap="realize" data-id="{{item._id}}">实现收入</button>
        <button size="mini" bindtap="removeItem" data-id="{{item._id}}" data-name="{{item.name}}">删除</button>
      </view>
    </view>
  </block>

  <view class="section">新建</view>
  <view class="nb-card">
    <input class="inp" placeholder="名称" value="{{name}}" bindinput="onName" />
    <amount-input value="{{amount}}" bind:change="onAmt" />
    <radio-group class="freq" bindchange="onFreq">
      <label class="freq-item"><radio value="weekly" checked="{{frequency === 'weekly'}}" />每周</label>
      <label class="freq-item"><radio value="monthly" checked="{{frequency === 'monthly'}}" />每月</label>
      <label class="freq-item"><radio value="yearly" checked="{{frequency === 'yearly'}}" />每年</label>
    </radio-group>
    <date-picker value="{{startDate}}" bind:change="onStart" />
    <account-picker accounts="{{accounts}}" value="{{accountId}}" bind:change="onAcc" />
    <button type="primary" class="btn" bindtap="create">保存</button>
  </view>
</view>
