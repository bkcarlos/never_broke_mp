page {
  background-color: #f5f5f5;
  color: #333333;
  font-size: 28rpx;
  box-sizing: border-box;
}

.nb-card {
  background: #fff;
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.nb-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.nb-muted {
  color: #999999;
  font-size: 24rpx;
}

.nb-primary-btn {
  background: #1aad19 !important;
  color: #fff !important;
  border-radius: 16rpx !important;
}

.nb-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

button[type='primary'] {
  font-weight: 500;
}

.page-hint {
  font-size: 24rpx;
  color: #999;
  padding: 0 24rpx 16rpx;
  line-height: 1.5;
}
